@page "/dashboard/tenants"
@layout DashboardLayout
@rendermode InteractiveServer
@inject Callio.Admin.Services.AdminApiClient Api

<PageTitle>Tenants</PageTitle>

<MudStack Spacing="3">
    <div class="callio-stat-row">
        <div class="callio-stat">
            <div class="callio-stat-label">Tenants</div>
            <div class="callio-stat-value">@_tenants.Count</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">With active plan</div>
            <div class="callio-stat-value">@_tenants.Count(x => !string.IsNullOrWhiteSpace(x.CurrentPlanName))</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">Knowledge-ready tenants</div>
            <div class="callio-stat-value">@_knowledgeOverview.TenantsWithDocuments</div>
        </div>
    </div>

    <div class="callio-stat-row">
        <div class="callio-stat">
            <div class="callio-stat-label">Knowledge files</div>
            <div class="callio-stat-value">@_knowledgeOverview.TotalDocuments</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">Storage used</div>
            <div class="callio-stat-value">@FormatFileSize(_knowledgeOverview.TotalStorageBytes)</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">Ready</div>
            <div class="callio-stat-value">@_knowledgeOverview.ReadyDocuments</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">Needs review</div>
            <div class="callio-stat-value">@_knowledgeOverview.AwaitingApprovalDocuments</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">Failed</div>
            <div class="callio-stat-value">@_knowledgeOverview.FailedDocuments</div>
        </div>
    </div>

    <MudPaper Class="callio-card pa-5" Elevation="0">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <div>
                <MudText Typo="Typo.h5">Tenant registry</MudText>
                <MudText Typo="Typo.body2" Class="callio-lead">Approved tenants that are now part of the Callio platform, along with a quick read on their knowledge library footprint.</MudText>
            </div>
            <MudTextField @bind-Value="_search"
                          Placeholder="Search tenant, contact, or email"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Outlined.Search" />
        </MudStack>

        <MudTable Items="FilteredTenants" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Tenant</MudTh>
                <MudTh>Contact</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Infrastructure</MudTh>
                <MudTh>Plan</MudTh>
                <MudTh>Created</MudTh>
                <MudTh>Tenant code</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudText Typo="Typo.subtitle2">@context.Name</MudText>
                    <MudText Typo="Typo.caption">Activated @context.ActivatedAt.ToLocalTime().ToString("dd MMM yyyy")</MudText>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@context.ContactName</MudText>
                    <MudText Typo="Typo.caption">@context.ContactEmail</MudText>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@(context.Status.Contains("Active", StringComparison.OrdinalIgnoreCase) ? Color.Success : Color.Warning)">
                        @context.Status
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="@GetProvisioningColor(context.Id)">
                        @GetProvisioningLabel(context.Id)
                    </MudChip>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small" Href="@($"/dashboard/infrastructure?tenantId={context.Id}")">
                        Inspect
                    </MudButton>
                </MudTd>
                <MudTd>
                    <MudText Typo="Typo.body2">@(context.CurrentPlanName ?? "Not assigned")</MudText>
                    <MudText Typo="Typo.caption">@(context.SubscriptionStatus ?? "No subscription")</MudText>
                </MudTd>
                <MudTd>@context.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
                <MudTd>@context.TenantCode</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private IReadOnlyList<Callio.Admin.Services.TenantItem> _tenants = [];
    private IReadOnlyList<Callio.Admin.Services.TenantInfrastructureStatusItem> _infrastructure = [];
    private Callio.Admin.Services.TenantKnowledgeDashboardOverviewItem _knowledgeOverview = new(0, 0, 0, 0, 0, 0, 0);
    private string _search = string.Empty;

    private IEnumerable<Callio.Admin.Services.TenantItem> FilteredTenants =>
        _tenants.Where(tenant =>
            string.IsNullOrWhiteSpace(_search)
            || tenant.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || tenant.ContactName.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || tenant.ContactEmail.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        _tenants = await Api.GetTenantsAsync();
        _infrastructure = await Api.GetTenantInfrastructureAsync();
        _knowledgeOverview = await Api.GetTenantKnowledgeOverviewAsync();
    }

    private Callio.Admin.Services.TenantInfrastructureStatusItem? GetProvisioning(int tenantId)
        => _infrastructure.FirstOrDefault(x => x.TenantId == tenantId);

    private Color GetProvisioningColor(int tenantId) => GetProvisioning(tenantId)?.Status switch
    {
        "Succeeded" => Color.Success,
        "InProgress" => Color.Info,
        "Failed" => Color.Error,
        "Pending" => Color.Warning,
        _ => Color.Default
    };

    private string GetProvisioningLabel(int tenantId) => GetProvisioning(tenantId)?.Status switch
    {
        "Succeeded" => "Healthy",
        "InProgress" => "In progress",
        "Failed" => "Failed",
        "Pending" => "Pending",
        _ => "Not started"
    };

    private static string FormatFileSize(long sizeBytes)
    {
        if (sizeBytes >= 1024L * 1024L * 1024L)
            return $"{sizeBytes / (1024d * 1024d * 1024d):0.##} GB";

        if (sizeBytes >= 1024L * 1024L)
            return $"{sizeBytes / (1024d * 1024d):0.##} MB";

        if (sizeBytes >= 1024L)
            return $"{sizeBytes / 1024d:0.##} KB";

        return $"{sizeBytes} B";
    }
}

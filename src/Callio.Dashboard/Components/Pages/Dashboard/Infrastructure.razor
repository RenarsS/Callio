@page "/dashboard/infrastructure"
@layout DashboardLayout
@rendermode InteractiveServer
@inject Callio.Admin.Services.AdminApiClient Api
@inject ISnackbar Snackbar

<PageTitle>Infrastructure</PageTitle>

<MudStack Spacing="3">
    <div class="callio-stat-row four">
        <div class="callio-stat">
            <div class="callio-stat-label">Tracked tenants</div>
            <div class="callio-stat-value">@Rows.Count</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">Provisioned</div>
            <div class="callio-stat-value">@Rows.Count(x => x.Infrastructure?.Status == "Succeeded")</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">In progress</div>
            <div class="callio-stat-value">@Rows.Count(x => x.Infrastructure?.Status == "InProgress")</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">Needs attention</div>
            <div class="callio-stat-value">@Rows.Count(x => x.Infrastructure is null || x.Infrastructure.Status == "Failed" || x.Infrastructure.KnowledgeConfigurationSetup?.Status == "Failed")</div>
        </div>
    </div>

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="7">
            <MudPaper Class="callio-card pa-5" Elevation="0">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <div>
                        <MudText Typo="Typo.h5">Infrastructure operations</MudText>
                        <MudText Typo="Typo.body2" Class="callio-lead">Track tenant provisioning, spot failures, and rerun infrastructure setup when a tenant needs another pass.</MudText>
                    </div>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" ButtonType="ButtonType.Button" OnClick="LoadAsync">Refresh</MudButton>
                </MudStack>

                <MudTextField @bind-Value="_search"
                              Placeholder="Search by tenant, contact, email, schema, or namespace"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Outlined.Search"
                              Margin="Margin.Dense"
                              Class="mb-4" />

                <MudTable Items="FilteredRows" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Tenant</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh>Storage</MudTh>
                        <MudTh>Updated</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd>
                            <MudText Typo="Typo.subtitle2">@context.Tenant.Name</MudText>
                            <MudText Typo="Typo.caption">@context.Tenant.ContactEmail</MudText>
                        </MudTd>
                        <MudTd>
                            <MudChip T="string" Size="Size.Small" Color="@GetInfrastructureColor(context.Infrastructure)">
                                @GetInfrastructureLabel(context.Infrastructure)
                            </MudChip>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Class="ml-2" Color="@GetKnowledgeConfigurationColor(context.Infrastructure)">
                                @GetKnowledgeConfigurationLabel(context.Infrastructure)
                            </MudChip>
                            @if (!string.IsNullOrWhiteSpace(context.Infrastructure?.FailedStep))
                            {
                                <MudText Typo="Typo.caption" Class="d-block mt-1">@context.Infrastructure.FailedStep</MudText>
                            }
                        </MudTd>
                        <MudTd>
                            <MudText Typo="Typo.body2">@(context.Infrastructure?.DatabaseSchema ?? "Not created")</MudText>
                            <MudText Typo="Typo.caption">@(context.Infrastructure?.VectorStoreNamespace ?? "No namespace")</MudText>
                        </MudTd>
                        <MudTd>@GetLastUpdatedLabel(context.Infrastructure)</MudTd>
                        <MudTd>
                            <MudButton Variant="Variant.Text" Color="Color.Primary" ButtonType="ButtonType.Button" OnClick="() => SelectTenant(context.Tenant.Id)">
                                Inspect
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" lg="5">
            <MudPaper Class="callio-card pa-5" Elevation="0">
                @if (SelectedRow is null)
                {
                    <MudText Typo="Typo.h6">Select a tenant</MudText>
                    <MudText Typo="Typo.body2" Class="callio-lead">Choose a tenant from the operations list to inspect the current provisioning state, resource names, failure details, and retry controls.</MudText>
                }
                else
                {
                    <MudText Typo="Typo.h5">@SelectedRow.Tenant.Name</MudText>
                    <MudText Typo="Typo.body2" Class="callio-lead">@SelectedRow.Tenant.ContactName - @SelectedRow.Tenant.ContactEmail</MudText>

                    <MudStack Row="true" Spacing="1" Class="mt-4">
                        <MudChip T="string" Size="Size.Small" Color="@GetInfrastructureColor(SelectedRow.Infrastructure)">
                            @GetInfrastructureLabel(SelectedRow.Infrastructure)
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@GetKnowledgeConfigurationColor(SelectedRow.Infrastructure)">
                            @GetKnowledgeConfigurationLabel(SelectedRow.Infrastructure)
                        </MudChip>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                            Tenant #@SelectedRow.Tenant.Id
                        </MudChip>
                    </MudStack>

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.subtitle2">Infrastructure resources</MudText>
                    <MudText Typo="Typo.body2">Schema: @(SelectedRow.Infrastructure?.DatabaseSchema ?? "Not provisioned yet")</MudText>
                    <MudText Typo="Typo.body2">Vector namespace: @(SelectedRow.Infrastructure?.VectorStoreNamespace ?? "Not provisioned yet")</MudText>
                    <MudText Typo="Typo.caption">Attempts: @(SelectedRow.Infrastructure?.AttemptCount ?? 0)</MudText>

                    @if (!string.IsNullOrWhiteSpace(SelectedRow.Infrastructure?.LastError))
                    {
                        <MudPaper Class="callio-card mt-4 pa-4" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Latest failure</MudText>
                            <MudText Typo="Typo.body2" Class="callio-lead">@SelectedRow.Infrastructure.LastError</MudText>
                        </MudPaper>
                    }

                    <MudStack Row="true" Spacing="2" Class="mt-4">
                        @if (SelectedRow.Infrastructure?.Status == "Failed")
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Warning"
                                       Disabled="_isProcessing"
                                       ButtonType="ButtonType.Button"
                                       OnClick="RetrySelectedAsync">
                                Retry failed step
                            </MudButton>
                        }

                        <MudButton Variant="@(SelectedRow.Infrastructure is null ? Variant.Filled : Variant.Outlined)"
                                   Color="Color.Primary"
                                   Disabled="@IsReprovisionDisabled"
                                   ButtonType="ButtonType.Button"
                                   OnClick="ReprovisionSelectedAsync">
                            @(SelectedRow.Infrastructure is null ? "Provision now" : "Run full reprovision")
                        </MudButton>
                    </MudStack>

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.subtitle2">Provisioning steps</MudText>
                    @if (SelectedRow.Infrastructure is null)
                    {
                        <MudText Typo="Typo.body2" Class="callio-lead">This tenant does not have a provisioning record yet. Use the action above to initialize infrastructure and start tracking lifecycle state.</MudText>
                    }
                    else
                    {
                        <MudTable Items="SelectedRow.Infrastructure.Steps" Dense="true" Hover="true" Class="mt-3">
                            <HeaderContent>
                                <MudTh>Step</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Attempts</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudText Typo="Typo.body2">@GetStepLabel(context.Name)</MudText>
                                    @if (!string.IsNullOrWhiteSpace(context.LastError))
                                    {
                                        <MudText Typo="Typo.caption">@context.LastError</MudText>
                                    }
                                </MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small" Color="@GetStepColor(context.Status)">@context.Status</MudChip>
                                </MudTd>
                                <MudTd>@context.AttemptCount</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.subtitle2">Knowledge configuration setup</MudText>
                    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mt-3">
                        <MudChip T="string" Size="Size.Small" Color="@GetKnowledgeConfigurationColor(SelectedRow.Infrastructure)">
                            @GetKnowledgeConfigurationLabel(SelectedRow.Infrastructure)
                        </MudChip>
                        @if (SelectedRow.Infrastructure?.KnowledgeConfigurationSetup?.ActiveConfigurationId is int configurationId)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">
                                Config #@configurationId
                            </MudChip>
                        }
                    </MudStack>

                    <MudText Typo="Typo.body2" Class="mt-3">
                        Attempts: @(SelectedRow.Infrastructure?.KnowledgeConfigurationSetup?.AttemptCount ?? 0)
                    </MudText>
                    <MudText Typo="Typo.caption">
                        Updated: @GetKnowledgeConfigurationUpdatedLabel(SelectedRow.Infrastructure)
                    </MudText>

                    @if (!string.IsNullOrWhiteSpace(SelectedRow.Infrastructure?.KnowledgeConfigurationSetup?.LastError))
                    {
                        <MudPaper Class="callio-card mt-4 pa-4" Elevation="0">
                            <MudText Typo="Typo.subtitle2">Configuration setup failure</MudText>
                            <MudText Typo="Typo.body2" Class="callio-lead">@SelectedRow.Infrastructure.KnowledgeConfigurationSetup.LastError</MudText>
                        </MudPaper>
                    }

                    @if (CanRetryKnowledgeConfiguration(SelectedRow.Infrastructure))
                    {
                        <MudStack Row="true" Spacing="2" Class="mt-4">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Warning"
                                       Disabled="_isProcessing"
                                       ButtonType="ButtonType.Button"
                                       OnClick="RetryKnowledgeConfigurationSelectedAsync">
                                Retry configuration setup
                            </MudButton>
                        </MudStack>
                    }

                    @if (SelectedRow.Infrastructure?.Settings is not null)
                    {
                        <MudDivider Class="my-4" />

                        <MudText Typo="Typo.subtitle2">Active knowledge configuration</MudText>
                        <MudText Typo="Typo.body2">Embedding: @SelectedRow.Infrastructure.Settings.EmbeddingProvider / @SelectedRow.Infrastructure.Settings.EmbeddingModel</MudText>
                        <MudText Typo="Typo.body2">Generation model: @SelectedRow.Infrastructure.Settings.GenerationModel</MudText>
                        <MudText Typo="Typo.body2">Chunking: @SelectedRow.Infrastructure.Settings.ChunkSize with @SelectedRow.Infrastructure.Settings.ChunkOverlap overlap</MudText>
                        <MudText Typo="Typo.body2">Retrieval: top @SelectedRow.Infrastructure.Settings.TopKRetrievalCount, final context max @SelectedRow.Infrastructure.Settings.MaximumChunksInFinalContext</MudText>
                        <MudText Typo="Typo.body2">Similarity threshold: @SelectedRow.Infrastructure.Settings.MinimumSimilarityThreshold</MudText>
                        <MudText Typo="Typo.body2">Allowed file types: @string.Join(", ", SelectedRow.Infrastructure.Settings.AllowedFileTypes)</MudText>
                        <MudText Typo="Typo.caption">
                            Max file size @FormatFileSize(SelectedRow.Infrastructure.Settings.MaximumFileSizeBytes), auto-process @(SelectedRow.Infrastructure.Settings.AutoProcessOnUpload ? "enabled" : "disabled"), manual approval @(SelectedRow.Infrastructure.Settings.ManualApprovalRequiredBeforeIndexing ? "required" : "not required"), versioning @(SelectedRow.Infrastructure.Settings.VersioningEnabled ? "enabled" : "disabled")
                        </MudText>
                    }
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    [SupplyParameterFromQuery(Name = "tenantId")]
    public int? TenantId { get; set; }

    private IReadOnlyList<Callio.Admin.Services.TenantItem> _tenants = [];
    private IReadOnlyList<Callio.Admin.Services.TenantInfrastructureStatusItem> _infrastructure = [];
    private string _search = string.Empty;
    private int? _selectedTenantId;
    private bool _isProcessing;

    private IReadOnlyList<InfrastructureRow> Rows =>
        _tenants
            .Select(tenant => new InfrastructureRow(
                tenant,
                _infrastructure.FirstOrDefault(item => item.TenantId == tenant.Id)))
            .OrderByDescending(row => GetPriority(row.Infrastructure))
            .ThenBy(row => row.Tenant.Name)
            .ToList();

    private IEnumerable<InfrastructureRow> FilteredRows =>
        Rows.Where(row =>
            string.IsNullOrWhiteSpace(_search)
            || row.Tenant.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || row.Tenant.ContactName.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || row.Tenant.ContactEmail.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || (row.Infrastructure?.DatabaseSchema?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
            || (row.Infrastructure?.VectorStoreNamespace?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));

    private InfrastructureRow? SelectedRow =>
        _selectedTenantId is null ? null : Rows.FirstOrDefault(x => x.Tenant.Id == _selectedTenantId.Value);

    private bool IsReprovisionDisabled =>
        _isProcessing || SelectedRow?.Infrastructure?.Status == "InProgress";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    protected override async Task OnParametersSetAsync()
    {
        if (TenantId.HasValue && TenantId != _selectedTenantId)
            _selectedTenantId = TenantId;

        await Task.CompletedTask;
    }

    private async Task LoadAsync()
    {
        _tenants = await Api.GetTenantsAsync();
        _infrastructure = await Api.GetTenantInfrastructureAsync();

        if (_selectedTenantId.HasValue && _tenants.All(x => x.Id != _selectedTenantId.Value))
            _selectedTenantId = null;

        if (_selectedTenantId is null)
        {
            var preferred = Rows.FirstOrDefault(x => x.Infrastructure?.Status == "Failed")
                            ?? Rows.FirstOrDefault(x => x.Infrastructure is null)
                            ?? Rows.FirstOrDefault();

            if (preferred is not null)
                _selectedTenantId = preferred.Tenant.Id;
        }
    }

    private void SelectTenant(int tenantId)
    {
        _selectedTenantId = tenantId;
    }

    private async Task RetrySelectedAsync()
    {
        if (SelectedRow?.Infrastructure is null)
            return;

        try
        {
            _isProcessing = true;
            await Api.RetryTenantInfrastructureAsync(SelectedRow.Tenant.Id);
            Snackbar.Add("Tenant infrastructure retry started.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task ReprovisionSelectedAsync()
    {
        if (SelectedRow is null)
            return;

        try
        {
            _isProcessing = true;
            await Api.ReprovisionTenantInfrastructureAsync(SelectedRow.Tenant.Id);
            Snackbar.Add("Tenant reprovisioning started.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task RetryKnowledgeConfigurationSelectedAsync()
    {
        if (SelectedRow?.Infrastructure is null)
            return;

        try
        {
            _isProcessing = true;
            await Api.RetryTenantKnowledgeConfigurationAsync(SelectedRow.Tenant.Id);
            Snackbar.Add("Tenant knowledge configuration setup retried.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private static string GetInfrastructureLabel(Callio.Admin.Services.TenantInfrastructureStatusItem? item)
        => item?.Status switch
        {
            "Succeeded" => "Healthy",
            "InProgress" => "In progress",
            "Failed" => "Failed",
            "Pending" => "Pending",
            _ => "Not provisioned"
        };

    private static Color GetInfrastructureColor(Callio.Admin.Services.TenantInfrastructureStatusItem? item)
        => item?.Status switch
        {
            "Succeeded" => Color.Success,
            "InProgress" => Color.Info,
            "Failed" => Color.Error,
            "Pending" => Color.Warning,
            _ => Color.Default
        };

    private static string GetKnowledgeConfigurationLabel(Callio.Admin.Services.TenantInfrastructureStatusItem? item)
        => item?.KnowledgeConfigurationSetup?.Status switch
        {
            "Succeeded" => "Config ready",
            "InProgress" => "Configuring",
            "Failed" => "Config failed",
            "Pending" => item.Status == "Succeeded" ? "Config queued" : "Waiting for infra",
            _ => item is null ? "Waiting for infra" : item.Status == "Succeeded" ? "Not started" : "Waiting for infra"
        };

    private static Color GetKnowledgeConfigurationColor(Callio.Admin.Services.TenantInfrastructureStatusItem? item)
        => item?.KnowledgeConfigurationSetup?.Status switch
        {
            "Succeeded" => Color.Success,
            "InProgress" => Color.Info,
            "Failed" => Color.Error,
            "Pending" => Color.Warning,
            _ => item?.Status == "Succeeded" ? Color.Warning : Color.Default
        };

    private static string GetKnowledgeConfigurationUpdatedLabel(Callio.Admin.Services.TenantInfrastructureStatusItem? item)
        => item?.KnowledgeConfigurationSetup?.UpdatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "Waiting for provisioning";

    private static string GetLastUpdatedLabel(Callio.Admin.Services.TenantInfrastructureStatusItem? item)
        => item?.UpdatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm") ?? "Not tracked";

    private static int GetPriority(Callio.Admin.Services.TenantInfrastructureStatusItem? item)
        => item?.KnowledgeConfigurationSetup?.Status == "Failed"
            ? 5
            : item?.Status switch
        {
            "Failed" => 4,
            null => 3,
            "InProgress" => 2,
            "Pending" => 1,
            _ => 0
        };

    private static string GetStepLabel(string stepName) => stepName switch
    {
        "database-schema" => "Database schema",
        "vector-store" => "Vector namespace",
        _ => stepName
    };

    private static Color GetStepColor(string status) => status switch
    {
        "Succeeded" => Color.Success,
        "InProgress" => Color.Info,
        "Failed" => Color.Error,
        _ => Color.Warning
    };

    private static bool CanRetryKnowledgeConfiguration(Callio.Admin.Services.TenantInfrastructureStatusItem? item)
        => item?.Status == "Succeeded" && item.KnowledgeConfigurationSetup?.Status == "Failed";

    private static string FormatFileSize(long bytes)
    {
        const long kilobyte = 1024;
        const long megabyte = kilobyte * 1024;

        return bytes >= megabyte
            ? $"{bytes / (decimal)megabyte:0.#} MB"
            : bytes >= kilobyte
                ? $"{bytes / (decimal)kilobyte:0.#} KB"
                : $"{bytes} B";
    }

    private sealed record InfrastructureRow(
        Callio.Admin.Services.TenantItem Tenant,
        Callio.Admin.Services.TenantInfrastructureStatusItem? Infrastructure);
}


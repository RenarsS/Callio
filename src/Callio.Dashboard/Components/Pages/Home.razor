@page "/"
@page "/dashboard"
@layout DashboardLayout
@rendermode InteractiveServer
@inject Services.AdminApiClient Api

<PageTitle>Dashboard overview</PageTitle>

<MudStack Spacing="3">
    <MudPaper Class="callio-card callio-card-strong pa-6" Elevation="0">
        <div class="callio-kicker">Operations overview</div>
        <MudText Typo="Typo.h3" GutterBottom="true">Review portal onboarding and keep the tenant registry operational.</MudText>
        <MudText Typo="Typo.body1" Class="callio-lead">
            This dashboard is the administrative side of the same Callio experience. Review incoming tenant requests, create approved tenants, and keep their infrastructure healthy after approval.
        </MudText>

        <MudStack Row="true" Spacing="2" Class="mt-5">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/dashboard/tenant-requests">Open tenant requests</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/dashboard/tenants">Open tenant registry</MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/dashboard/infrastructure">Open infrastructure</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/dashboard/plans">Open plan catalog</MudButton>
        </MudStack>
    </MudPaper>

    <div class="callio-stat-row four">
        <div class="callio-stat">
            <div class="callio-stat-label">Pending requests</div>
            <div class="callio-stat-value">@PendingCount</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">Approved requests</div>
            <div class="callio-stat-value">@ApprovedCount</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">Live tenants</div>
            <div class="callio-stat-value">@_tenants.Count</div>
        </div>
        <div class="callio-stat">
            <div class="callio-stat-label">Infra issues</div>
            <div class="callio-stat-value">@InfrastructureIssues</div>
        </div>
    </div>

    <div class="callio-grid-two">
        <MudPaper Class="callio-card pa-5" Elevation="0">
            <MudText Typo="Typo.h5" GutterBottom="true">Queue health</MudText>
            <MudText Typo="Typo.body2" Class="callio-lead mb-4">Latest portal submissions waiting for approval or rejection.</MudText>

            <MudTable Items="@_requests.Take(5)" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Tenant</MudTh>
                    <MudTh>Company</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Requested</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>@context.TenantName</MudTd>
                    <MudTd>@context.CompanyName</MudTd>
                    <MudTd><MudChip T="string" Color="@GetRequestColor(context.Status)" Size="Size.Small">@GetRequestStatusLabel(context.Status)</MudChip></MudTd>
                    <MudTd>@context.RequestedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>

        <MudPaper Class="callio-card pa-5" Elevation="0">
            <MudText Typo="Typo.h5" GutterBottom="true">Recent tenants</MudText>
            <MudText Typo="Typo.body2" Class="callio-lead mb-4">Latest approved tenants and the plan state currently linked to each one.</MudText>

            <MudTable Items="@_tenants.Take(5)" Dense="true" Hover="true">
                <HeaderContent>
                    <MudTh>Tenant</MudTh>
                    <MudTh>Plan</MudTh>
                    <MudTh>Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudText Typo="Typo.subtitle2">@context.Name</MudText>
                        <MudText Typo="Typo.caption">@context.ContactEmail</MudText>
                    </MudTd>
                    <MudTd>@(context.CurrentPlanName ?? "Not assigned")</MudTd>
                    <MudTd>@(context.SubscriptionStatus ?? "No subscription")</MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    </div>

    <MudPaper Class="callio-card pa-5" Elevation="0">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
            <div>
                <MudText Typo="Typo.h5">Infrastructure watch</MudText>
                <MudText Typo="Typo.body2" Class="callio-lead">Provisioning state for tracked tenants, with a fast path into retry and reprovision controls.</MudText>
            </div>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/dashboard/infrastructure">Open operations</MudButton>
        </MudStack>

        <MudTable Items="InfrastructurePreview" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>Tenant</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Failed step</MudTh>
                <MudTh>Updated</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.TenantName</MudTd>
                <MudTd><MudChip T="string" Size="Size.Small" Color="@GetInfrastructureColor(context.Status)">@GetInfrastructureLabel(context.Status)</MudChip></MudTd>
                <MudTd>@(context.FailedStep ?? "None")</MudTd>
                <MudTd>@context.UpdatedAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm")</MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private IReadOnlyList<Services.TenantRequestItem> _requests = [];
    private IReadOnlyList<Services.TenantItem> _tenants = [];
    private IReadOnlyList<Services.PlanItem> _plans = [];
    private IReadOnlyList<Services.TenantInfrastructureStatusItem> _infrastructure = [];

    private int PendingCount => _requests.Count(x => x.Status == 1);
    private int ApprovedCount => _requests.Count(x => x.Status == 2);
    private int InfrastructureIssues =>
        _infrastructure.Count(x => x.Status == "Failed") +
        _tenants.Count(x => _infrastructure.All(item => item.TenantId != x.Id));

    private IEnumerable<InfrastructurePreviewItem> InfrastructurePreview =>
        _infrastructure
            .OrderByDescending(x => x.Status == "Failed")
            .ThenByDescending(x => x.UpdatedAtUtc)
            .Take(5)
            .Select(x => new InfrastructurePreviewItem(
                _tenants.FirstOrDefault(t => t.Id == x.TenantId)?.Name ?? $"Tenant #{x.TenantId}",
                x.Status,
                x.FailedStep,
                x.UpdatedAtUtc));

    protected override async Task OnInitializedAsync()
    {
        _requests = await Api.GetTenantRequestsAsync();
        _tenants = await Api.GetTenantsAsync();
        _plans = await Api.GetPlansAsync();
        _infrastructure = await Api.GetTenantInfrastructureAsync();
    }

    private static Color GetRequestColor(int status) => status switch { 2 => Color.Success, 3 => Color.Error, _ => Color.Warning };
    private static string GetRequestStatusLabel(int status) => status switch { 2 => "Approved", 3 => "Rejected", _ => "Pending" };
    private static Color GetInfrastructureColor(string status) => status switch { "Succeeded" => Color.Success, "InProgress" => Color.Info, "Failed" => Color.Error, _ => Color.Warning };
    private static string GetInfrastructureLabel(string status) => status switch { "Succeeded" => "Healthy", "InProgress" => "In progress", "Failed" => "Failed", _ => status };

    private sealed record InfrastructurePreviewItem(string TenantName, string Status, string? FailedStep, DateTime UpdatedAtUtc);
}

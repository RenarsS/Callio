@page "/login"
@layout CenteredLayout

<MudPaper Class="dashboard-login-card pa-8" Style="
    width: 420px;
    max-width: 100%;
    border-radius: 8px;
    background: #1a1d2e;
    border: 1px solid rgba(255,255,255,0.08);
    box-shadow: 0 24px 64px rgba(0,0,0,0.5);
">
    <div style="display:flex;justify-content:center;margin-bottom:28px;">
        <div style="
            width:48px;height:48px;border-radius:8px;
            background:rgba(99,102,241,0.15);
            border:1px solid rgba(99,102,241,0.35);
            display:flex;align-items:center;justify-content:center;">
            <MudIcon Icon="@Icons.Material.Filled.Bolt" Style="color:#6366f1;font-size:26px;" />
        </div>
    </div>

    <MudText Typo="Typo.h5" Align="Align.Center" Style="font-weight:700;margin-bottom:6px;">
        Welcome back
    </MudText>
    <MudText Typo="Typo.body2" Align="Align.Center" Style="opacity:0.5;margin-bottom:32px;">
        Sign in to your account
    </MudText>

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@Error</MudAlert>
    }

    <form method="post" action="/auth/login">
        <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />

        <label class="dashboard-login-label" for="admin-email">Email address</label>
        <input id="admin-email"
               class="dashboard-login-input"
               type="email"
               name="Email"
               autocomplete="username"
               required />

        <label class="dashboard-login-label" for="admin-password">Password</label>
        <input id="admin-password"
               class="dashboard-login-input"
               type="password"
               name="Password"
               autocomplete="current-password"
               required />

        <MudButton ButtonType="ButtonType.Submit"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   FullWidth="true"
                   Size="Size.Large"
                   Style="border-radius:8px;font-weight:600;letter-spacing:0.2px;padding:12px;margin-top:20px;">
            Sign in
        </MudButton>
    </form>
</MudPaper>

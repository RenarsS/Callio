@inherits LayoutComponentBase

<MudThemeProvider Theme="MainLayout.AppTheme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="dashboard-shell">
    <MudLayout>
        <MudAppBar Elevation="0" Fixed="true" Class="dashboard-appbar">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           OnClick="ToggleDrawer" />

            <div class="dashboard-title-block">
                <MudText Typo="Typo.h6" Class="dashboard-title">Callio Command Center</MudText>
                <MudText Typo="Typo.caption">Tenant review and operational control</MudText>
            </div>

            <MudSpacer />

            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Class="dashboard-chip">
                Shared backend
            </MudChip>

            <MudAvatar Class="dashboard-avatar">CA</MudAvatar>
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen"
                   Variant="DrawerVariant.Responsive"
                   Breakpoint="Breakpoint.Lg"
                   Overlay="false"
                   Elevation="0"
                   Class="dashboard-drawer">
            <div class="drawer-brand">
                <div class="drawer-brand-icon">C</div>
                <div>
                    <MudText Typo="Typo.subtitle1" Class="drawer-brand-title">Callio Dashboard</MudText>
                    <MudText Typo="Typo.caption">Portal review, tenant registry, plan control</MudText>
                </div>
            </div>

            <MudNavMenu Bordered="false" Rounded="true">
                <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.SpaceDashboard">Overview</MudNavLink>
                <MudNavLink Href="/dashboard/tenant-requests" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Outlined.FactCheck">Tenant requests</MudNavLink>
                <MudNavLink Href="/dashboard/tenants" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Outlined.Domain">Tenants</MudNavLink>
                <MudNavLink Href="/dashboard/plans" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Outlined.Payments">Plans &amp; quotas</MudNavLink>
            </MudNavMenu>
        </MudDrawer>

        <MudMainContent Class="dashboard-main">
            <div class="dashboard-page-content">
                @Body
            </div>
        </MudMainContent>
    </MudLayout>
</div>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}

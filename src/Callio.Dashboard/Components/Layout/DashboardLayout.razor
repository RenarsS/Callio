@inherits LayoutComponentBase
@layout MainLayout

@inject NavigationManager Nav

<div class="dashboard-shell">
    <MudLayout>

        <MudAppBar Elevation="0" Class="dashboard-appbar">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           OnClick="ToggleDrawer" />

            <MudText Typo="Typo.h6" Class="ml-2" Style="font-weight:600; letter-spacing:-0.3px;">
                @_pageTitle
            </MudText>

            <MudSpacer />

            <MudIconButton Icon="@Icons.Material.Outlined.Notifications" Color="Color.Inherit" />
            <MudAvatar Style="width:36px;height:36px;background:#6366f1;font-size:14px;cursor:pointer;" Class="ml-2">
                JD
            </MudAvatar>
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen"
                   Variant="DrawerVariant.Responsive"
                   Breakpoint="Breakpoint.Md"
                   Elevation="0"
                   Class="dashboard-drawer">

            <div class="drawer-brand">
                <div class="drawer-brand-icon">
                    <MudIcon Icon="@Icons.Material.Filled.Bolt" Style="color:#6366f1;font-size:22px;" />
                </div>
                <MudText Typo="Typo.h6" Style="font-weight:700;letter-spacing:-0.5px;">AppName</MudText>
            </div>

            <MudDivider Class="mb-2" />

            <MudNavMenu>
                <MudNavLink Href="/dashboard"
                            Match="NavLinkMatch.All"
                            Icon="@Icons.Material.Outlined.Dashboard"
                            IconColor="Color.Primary">
                    Dashboard
                </MudNavLink>

                <MudNavLink Href="/analytics"
                            Icon="@Icons.Material.Outlined.BarChart"
                            IconColor="Color.Primary">
                    Analytics
                </MudNavLink>

                <MudNavLink Href="/settings"
                            Icon="@Icons.Material.Outlined.Settings"
                            IconColor="Color.Primary">
                    Settings
                </MudNavLink>
            </MudNavMenu>

            <MudSpacer />

            <div class="drawer-user-strip">
                <MudAvatar Style="width:32px;height:32px;background:#6366f1;font-size:12px;">JD</MudAvatar>
                <div class="drawer-user-info">
                    <MudText Typo="Typo.body2" Style="font-weight:600;line-height:1.2;">John Doe</MudText>
                    <MudText Typo="Typo.caption" Style="opacity:0.5;">john@example.com</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Outlined.Logout"
                               Size="Size.Small"
                               Color="Color.Default" />
            </div>
        </MudDrawer>

        <MudMainContent Class="dashboard-main">
            <div class="dashboard-page-content">
                @Body
            </div>
        </MudMainContent>

    </MudLayout>
</div>

@code {
    private bool _drawerOpen = true;
    private string _pageTitle = "Dashboard";

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}

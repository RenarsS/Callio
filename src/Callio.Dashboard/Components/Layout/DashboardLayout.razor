@inherits LayoutComponentBase

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="dashboard-shell">
    <MudLayout>
        <MudAppBar Elevation="0" Fixed="true" Class="dashboard-appbar">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           OnClick="ToggleDrawer"
                           AriaLabel="Toggle navigation" />
            <MudText Typo="Typo.h6" Class="ml-2 dashboard-title">Callio Control Center</MudText>
            <MudSpacer />
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Class="mr-3">
                Admin workspace
            </MudChip>
            <MudAvatar Style="width:36px;height:36px;background:#6366f1;font-size:14px;">CA</MudAvatar>
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen"
                   Variant="DrawerVariant.Responsive"
                   Breakpoint="Breakpoint.Md"
                   Overlay="true"
                   Elevation="0"
                   Class="dashboard-drawer">
            <div class="drawer-brand">
                <div class="drawer-brand-icon">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="color:#7c3aed;font-size:20px;" />
                </div>
                <div>
                    <MudText Typo="Typo.subtitle1" Style="font-weight:700;">Callio Dashboard</MudText>
                    <MudText Typo="Typo.caption">Tenant operations &amp; plans</MudText>
                </div>
            </div>

            <MudDivider Class="mb-2" />

            <MudNavMenu Bordered="false" Rounded="true">
                <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Outlined.SpaceDashboard">
                    Overview
                </MudNavLink>
                <MudNavLink Href="/dashboard/tenant-requests" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Outlined.FactCheck">
                    Tenant requests
                </MudNavLink>
                <MudNavLink Href="/dashboard/plans" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Outlined.Payments">
                    Plans &amp; quotas
                </MudNavLink>
                <MudNavLink Href="/dashboard/tenants" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Outlined.Domain">
                    Tenants
                </MudNavLink>
            </MudNavMenu>

            <MudPaper Class="sidebar-cta" Elevation="0">
                <MudText Typo="Typo.subtitle2" Class="mb-1">Multi-tenant RAG at a glance</MudText>
                <MudText Typo="Typo.body2">
                    Review onboarding, shape pricing, and prepare quota scaffolding for ingestion and usage telemetry.
                </MudText>
            </MudPaper>
        </MudDrawer>

        <MudMainContent Class="dashboard-main">
            <div class="dashboard-page-content">
                @Body
            </div>
        </MudMainContent>
    </MudLayout>
</div>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
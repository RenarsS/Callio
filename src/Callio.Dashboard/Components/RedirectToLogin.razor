@inject NavigationManager Navigation

@code {
    protected override void OnInitialized()
    {
        var relativeUri = Navigation.ToBaseRelativePath(Navigation.Uri);
        var returnUrl = string.IsNullOrWhiteSpace(relativeUri) ? "/dashboard" : $"/{relativeUri}";
        Navigation.NavigateTo($"/login?returnUrl={Uri.EscapeDataString(returnUrl)}", replace: true);
    }
}

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "MassTransit": {
    "Transport": "InMemory",
    "RabbitMq": {
      "Host": "localhost",
      "VirtualHost": "/",
      "Username": "guest",
      "Password": "guest"
    },
    "AzureServiceBus": {
      "ConnectionString": ""
    }
  },
  "ConnectionStrings": {
    "CallioDb": "Server=Renars\\SQLEXPRESS;Database=Callio;Trusted_Connection=True;TrustServerCertificate=True;",
    "CallioTenantsDb": "Server=Renars\\SQLEXPRESS;Database=Callio_Tenants;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "TenantProvisioning": {
    "SchemaPrefix": "tenant_",
    "VectorNamespacePrefix": "tenant-",
    "VectorStoreProvider": "Local",
    "AzureCosmosConnectionString": "",
    "AzureCosmosDatabaseName": "callio-vectors",
    "AzureCosmosVectorDimensions": 1536,
    "AzureCosmosVectorIndexType": "QuantizedFlat"
  },
  "TenantKnowledgeConfiguration": {
    "EmbeddingProvider": "openai",
    "EmbeddingModel": "text-embedding-3-small",
    "GenerationModel": "gpt-4.1-mini",
    "DefaultSystemPrompt": "You are Callio's knowledge assistant. Answer using tenant-approved knowledge only and clearly state when the knowledge base does not contain the answer.",
    "DefaultAssistantInstructionPrompt": "Retrieve the most relevant approved chunks, prioritize precision over coverage, and avoid unsupported claims.",
    "ChunkSize": 800,
    "ChunkOverlap": 120,
    "RetrievalTopK": 8,
    "MaximumChunksInFinalContext": 6,
    "MinimumSimilarityThreshold": 0.7,
    "AllowedFileTypes": [ ".pdf", ".docx", ".txt", ".md" ],
    "MaximumFileSizeBytes": 10485760,
    "AutoProcessOnUpload": true,
    "ManualApprovalRequiredBeforeIndexing": false,
    "VersioningEnabled": true
  },
  "TenantKnowledgeIngestion": {
    "BlobProvider": "Local",
    "LocalStorageRootPath": "App_Data\\tenant-knowledge",
    "AzureBlobConnectionString": "",
    "AzureBlobContainerName": "tenant-knowledge",
    "EmbeddingProvider": "Deterministic",
    "DeterministicEmbeddingDimensions": 128,
    "AzureOpenAIEndpoint": "",
    "AzureOpenAIKey": "",
    "AzureOpenAIEmbeddingDeployment": "",
    "AzureOpenAIApiVersion": "2024-06-01"
  },
  "TenantGeneration": {
    "CompletionProvider": "Deterministic",
    "DefaultPromptKey": "knowledge-answer",
    "GenerationModel": "gpt-4.1-mini",
    "MaxOutputTokens": 800,
    "Temperature": 0.2,
    "SourceExcerptMaxCharacters": 1800,
    "BlobContentMaxCharacters": 3000,
    "AzureOpenAIEndpoint": "",
    "AzureOpenAIKey": "",
    "AzureOpenAIChatDeployment": "",
    "AzureOpenAIApiVersion": "2024-06-01",
    "PromptTemplates": [
      {
        "Key": "knowledge-answer",
        "Name": "Knowledge answer",
        "Description": "Answer from tenant knowledge context.",
        "SystemPrompt": "You are Callio's tenant knowledge generation assistant. Use only the supplied context. Say when the retrieved tenant knowledge does not contain enough information.",
        "UserPromptTemplate": "Question:\n{{input}}\n\nTenant assistant instructions:\n{{assistantInstructionPrompt}}\n\nRetrieved context:\n{{context}}\n\nWrite a direct answer and cite the source numbers that support it.",
        "DataSources": [
          {
            "SourceKind": "KnowledgeChunk"
          }
        ]
      }
    ]
  }
}

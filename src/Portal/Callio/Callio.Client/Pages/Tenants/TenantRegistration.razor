@page "/tenant-registration"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject Callio.Client.Services.TenantRequestApi TenantRequestApi

<PageTitle>Start onboarding</PageTitle>

<MudGrid Spacing="3">
    <MudItem xs="12" lg="4">
        <MudPaper Class="callio-card callio-card-strong pa-5" Elevation="0">
            <div class="callio-kicker">Portal onboarding</div>
            <MudText Typo="Typo.h4" GutterBottom="true">Register the first customer user and request a tenant.</MudText>
            <MudText Typo="Typo.body2" Class="callio-lead">
                This form covers the full handoff into Callio: account owner details, tenant name, company context, and any notes the dashboard reviewer should see.
            </MudText>

            <MudDivider Class="my-4" />

            <div class="callio-step">
                <div class="callio-step-number">1</div>
                <div>
                    <MudText Typo="Typo.subtitle1">Create portal identity</MudText>
                    <MudText Typo="Typo.body2" Class="callio-lead">The first user is created immediately and becomes the tenant owner after approval.</MudText>
                </div>
            </div>

            <div class="callio-step">
                <div class="callio-step-number">2</div>
                <div>
                    <MudText Typo="Typo.subtitle1">Submit for review</MudText>
                    <MudText Typo="Typo.body2" Class="callio-lead">The tenant request enters the dashboard queue with a pending status and review note support.</MudText>
                </div>
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" lg="8">
        <MudStack Spacing="3">
            <MudPaper Class="callio-card pa-5" Elevation="0">
                <MudText Typo="Typo.h5" GutterBottom="true">Account owner</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.FirstName" Label="First name" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.LastName" Label="Last name" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Email" Label="Email" Variant="Variant.Outlined" InputType="InputType.Email" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.Password" Label="Password" Variant="Variant.Outlined" InputType="InputType.Password" Required="true" />
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudPaper Class="callio-card pa-5" Elevation="0">
                <MudText Typo="Typo.h5" GutterBottom="true">Tenant request</MudText>
                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.CompanyName" Label="Company name" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField @bind-Value="_model.TenantName" Label="Tenant name" Variant="Variant.Outlined" Required="true" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Notes" Label="Implementation notes" Variant="Variant.Outlined" Lines="5" />
                    </MudItem>
                </MudGrid>

                <MudStack Row="true" Spacing="2" Class="mt-5">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Button" Disabled="@(_submitting || !CanSubmit)" OnClick="SubmitAsync">
                        @(_submitting ? "Submitting..." : "Register user and submit tenant request")
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/tenant-request-status">Check existing request</MudButton>
                </MudStack>
            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
            }

            @if (_result is not null)
            {
                <MudPaper Class="callio-card pa-5" Elevation="0">
                    <div class="callio-kicker">Request submitted</div>
                    <MudText Typo="Typo.h5" GutterBottom="true">Callio received your onboarding request.</MudText>
                    <MudText Typo="Typo.body2" Class="callio-lead">@_result.Message</MudText>

                    <MudStack Row="true" Spacing="2" Class="mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@StatusHref">Open request status</MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/">Back to overview</MudButton>
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    </MudItem>
</MudGrid>

@code {
    private readonly TenantRegistrationVm _model = new();
    private bool _submitting;
    private string? _error;
    private Callio.Client.Services.PortalRegistrationResponse? _result;

    private bool CanSubmit =>
        !string.IsNullOrWhiteSpace(_model.FirstName) &&
        !string.IsNullOrWhiteSpace(_model.LastName) &&
        !string.IsNullOrWhiteSpace(_model.Email) &&
        !string.IsNullOrWhiteSpace(_model.Password) &&
        !string.IsNullOrWhiteSpace(_model.CompanyName) &&
        !string.IsNullOrWhiteSpace(_model.TenantName);

    private string StatusHref =>
        _result is null
            ? "/tenant-request-status"
            : $"/tenant-request-status?requestId={_result.TenantRequestId}&email={Uri.EscapeDataString(_result.Email)}";

    private async Task SubmitAsync()
    {
        if (!CanSubmit)
        {
            _error = "Complete the required account and tenant fields before submitting.";
            return;
        }

        _submitting = true;
        _error = null;
        _result = null;

        try
        {
            _result = await TenantRequestApi.RegisterUserAndTenantAsync(new Callio.Client.Services.RegisterPortalUserAndTenantRequest(
                _model.Email,
                _model.Password,
                _model.FirstName,
                _model.LastName,
                _model.CompanyName,
                _model.TenantName,
                _model.Notes));
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class TenantRegistrationVm
    {
        public string FirstName { get; set; } = string.Empty;
        public string LastName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string CompanyName { get; set; } = string.Empty;
        public string TenantName { get; set; } = string.Empty;
        public string? Notes { get; set; }
    }
}

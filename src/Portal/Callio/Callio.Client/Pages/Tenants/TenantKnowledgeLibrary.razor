@page "/tenant-knowledge-library"
@page "/tenant-knowledge-browse"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using Callio.Client.Models
@inject Callio.Client.Services.PortalSessionService PortalSessionService
@inject Callio.Client.Services.TenantKnowledgeSettingsApi TenantKnowledgeSettingsApi
@inject Callio.Client.Services.TenantKnowledgeDocumentsApi TenantKnowledgeDocumentsApi
@inject NavigationManager Navigation

<PageTitle>Knowledge browsing</PageTitle>

@if (_loadingSession)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_session is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Redirecting to sign in...
    </MudAlert>
}
else if (_tenantId is null)
{
    <TenantWorkspaceNav Session="_session" />

    <MudPaper Class="callio-card pa-5" Elevation="0">
        <MudText Typo="Typo.h5" GutterBottom="true">Knowledge browsing unlocks after tenant approval</MudText>
        <MudText Typo="Typo.body2" Class="callio-lead">
            This account has not been linked to an approved tenant yet. Check provisioning to follow approval and infrastructure progress.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/tenant-provisioning" Class="mt-4">
            Open provisioning
        </MudButton>
    </MudPaper>
}
else
{
    <TenantWorkspaceNav Session="_session" />

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="4">
            <MudStack Spacing="3">
                <MudPaper Class="callio-card callio-card-strong pa-5" Elevation="0">
                    <div class="callio-kicker">Tenant knowledge browsing</div>
                    <MudText Typo="Typo.h4" GutterBottom="true">Browse indexed tenant documents without mixing in upload work.</MudText>
                    <MudText Typo="Typo.body2" Class="callio-lead">
                        Filter the document library by category or tag, then sort by the metadata that matters for review.
                    </MudText>
                    <MudStack Row="true" Spacing="2" Class="mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/tenant-knowledge-upload">
                            Upload knowledge
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/tenant-knowledge-settings">
                            Settings
                        </MudButton>
                    </MudStack>
                </MudPaper>

                @if (_documents.Count > 0)
                {
                    <div class="callio-stat-row">
                        <div class="callio-stat">
                            <div class="callio-stat-label">Visible</div>
                            <div class="callio-stat-value">@_filteredDocuments.Count</div>
                        </div>
                        <div class="callio-stat">
                            <div class="callio-stat-label">Ready</div>
                            <div class="callio-stat-value">@_filteredDocuments.Count(x => x.ProcessingStatus == "Ready")</div>
                        </div>
                        <div class="callio-stat">
                            <div class="callio-stat-label">Storage</div>
                            <div class="callio-stat-value">@FormatCompactFileSize(_filteredDocuments.Sum(x => x.SizeBytes))</div>
                        </div>
                    </div>
                }

                @if (_settings is not null)
                {
                    <MudPaper Class="callio-card pa-5" Elevation="0">
                        <MudText Typo="Typo.h6" GutterBottom="true">Current intake rules</MudText>
                        <div class="callio-detail-list mt-3">
                            <div class="callio-detail-item">
                                <span>Allowed types</span>
                                <strong>@string.Join(", ", _settings.AllowedFileTypes)</strong>
                            </div>
                            <div class="callio-detail-item">
                                <span>Max file size</span>
                                <strong>@FormatFileSize(_settings.MaximumFileSizeBytes)</strong>
                            </div>
                            <div class="callio-detail-item">
                                <span>Approval gate</span>
                                <strong>@(_settings.ManualApprovalRequiredBeforeIndexing ? "Manual review" : "Immediate indexing")</strong>
                            </div>
                        </div>
                    </MudPaper>
                }
            </MudStack>
        </MudItem>

        <MudItem xs="12" lg="8">
            <MudStack Spacing="3">
                @if (!string.IsNullOrWhiteSpace(_feedbackMessage))
                {
                    <MudAlert Severity="@_feedbackSeverity" Variant="Variant.Outlined">@_feedbackMessage</MudAlert>
                }

                <MudPaper Class="callio-card pa-5" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <div>
                            <MudText Typo="Typo.h5">Browse knowledge documents</MudText>
                            <MudText Typo="Typo.body2" Class="callio-lead">
                                Use category and tag filters together, then sort by category, tags, status, size, title, or upload date.
                            </MudText>
                        </div>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            @_filteredDocuments.Count of @_documents.Count document(s)
                        </MudChip>
                    </MudStack>

                    <MudGrid Class="mb-4">
                        <MudItem xs="12" md="6">
                            <label class="callio-filter-label" for="knowledge-category-filter">Category filter</label>
                            <select id="knowledge-category-filter" class="callio-filter-select" @bind="_selectedCategoryId" @bind:after="ApplyDocumentView">
                                <option value="0">All categories</option>
                                <option value="-1">Uncategorized</option>
                                @foreach (var category in _categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <label class="callio-filter-label" for="knowledge-tag-filter">Tag filter</label>
                            <select id="knowledge-tag-filter" class="callio-filter-select" @bind="_selectedTagId" @bind:after="ApplyDocumentView">
                                <option value="0">All tags</option>
                                @foreach (var tag in _tags)
                                {
                                    <option value="@tag.Id">@tag.Name</option>
                                }
                            </select>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <label class="callio-filter-label" for="knowledge-sort">Sort by</label>
                            <select id="knowledge-sort" class="callio-filter-select" @bind="_sortBy" @bind:after="ApplyDocumentView">
                                <option value="@KnowledgeDocumentSort.Newest">Newest upload</option>
                                <option value="@KnowledgeDocumentSort.Oldest">Oldest upload</option>
                                <option value="@KnowledgeDocumentSort.Title">Title</option>
                                <option value="@KnowledgeDocumentSort.Category">Category</option>
                                <option value="@KnowledgeDocumentSort.Tags">Tags</option>
                                <option value="@KnowledgeDocumentSort.Status">Status</option>
                                <option value="@KnowledgeDocumentSort.SizeLargest">Largest size</option>
                                <option value="@KnowledgeDocumentSort.SizeSmallest">Smallest size</option>
                            </select>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Class="h-100">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@_loading" OnClick="ClearFilters">
                                    Clear filters
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_loading" OnClick="LoadAsync">
                                    @(_loading ? "Refreshing..." : "Refresh")
                                </MudButton>
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    @if (_loading)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                    }

                    @if (_documents.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="callio-lead">
                            No documents have been uploaded for this tenant yet.
                        </MudText>
                    }
                    else if (_filteredDocuments.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="callio-lead">
                            No documents match the selected category and tag filters.
                        </MudText>
                    }
                    else
                    {
                        <MudTable Items="_filteredDocuments" Dense="true" Hover="true">
                            <HeaderContent>
                                <MudTh>Document</MudTh>
                                <MudTh>Category</MudTh>
                                <MudTh>Tags</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Size</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <MudText Typo="Typo.subtitle2">@context.Title</MudText>
                                    <MudText Typo="Typo.caption">@context.OriginalFileName</MudText>
                                </MudTd>
                                <MudTd>@GetCategoryName(context)</MudTd>
                                <MudTd>
                                    @if (context.Tags.Count == 0)
                                    {
                                        <MudText Typo="Typo.caption">No tags</MudText>
                                    }
                                    else
                                    {
                                        <div class="callio-plan-card-quotas">
                                            @foreach (var tag in context.Tags)
                                            {
                                                <div class="callio-plan-card-quota">@tag.Name</div>
                                            }
                                        </div>
                                    }
                                </MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small" Color="@GetDocumentColor(context.ProcessingStatus)">
                                        @context.ProcessingStatus
                                    </MudChip>
                                </MudTd>
                                <MudTd>@FormatFileSize(context.SizeBytes)</MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudPaper>
            </MudStack>
        </MudItem>
    </MudGrid>
}

@code {
    private PortalUserSession? _session;
    private int? _tenantId;
    private bool _loadingSession = true;
    private bool _loading;
    private string? _feedbackMessage;
    private Severity _feedbackSeverity = Severity.Info;
    private PortalTenantKnowledgeSettingsResponse? _settings;
    private IReadOnlyList<PortalKnowledgeCategoryResponse> _categories = [];
    private IReadOnlyList<PortalKnowledgeTagResponse> _tags = [];
    private List<PortalKnowledgeDocumentResponse> _documents = [];
    private List<PortalKnowledgeDocumentResponse> _filteredDocuments = [];
    private int _selectedCategoryId;
    private int _selectedTagId;
    private KnowledgeDocumentSort _sortBy = KnowledgeDocumentSort.Newest;

    protected override async Task OnInitializedAsync()
    {
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        _session = await PortalSessionService.RequireAuthenticatedAsync(returnUrl);
        _tenantId = _session?.TenantId;
        _loadingSession = false;

        if (_tenantId is > 0)
            await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (_tenantId is not > 0)
            return;

        _loading = true;
        _feedbackMessage = null;

        try
        {
            _settings = await TenantKnowledgeSettingsApi.GetSettingsAsync(_tenantId.Value)
                        ?? await TenantKnowledgeSettingsApi.CreateDefaultAsync(_tenantId.Value);

            _categories = await TenantKnowledgeDocumentsApi.GetCategoriesAsync(_tenantId.Value);
            _tags = await TenantKnowledgeDocumentsApi.GetTagsAsync(_tenantId.Value);
            _documents = (await TenantKnowledgeDocumentsApi.GetDocumentsAsync(_tenantId.Value)).ToList();
            ApplyDocumentView();
        }
        catch (Exception ex)
        {
            _settings = null;
            _categories = [];
            _tags = [];
            _documents = [];
            _filteredDocuments = [];
            SetFeedback(Severity.Error, ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyDocumentView()
        => _filteredDocuments = SortDocuments(FilterDocuments()).ToList();

    private IEnumerable<PortalKnowledgeDocumentResponse> FilterDocuments()
    {
        var documents = _documents.AsEnumerable();

        documents = _selectedCategoryId switch
        {
            -1 => documents.Where(document => document.Category is null),
            > 0 => documents.Where(document => document.Category?.Id == _selectedCategoryId),
            _ => documents
        };

        if (_selectedTagId > 0)
            documents = documents.Where(document => document.Tags.Any(tag => tag.Id == _selectedTagId));

        return documents;
    }

    private IEnumerable<PortalKnowledgeDocumentResponse> SortDocuments(IEnumerable<PortalKnowledgeDocumentResponse> documents)
        => _sortBy switch
        {
            KnowledgeDocumentSort.Oldest => documents
                .OrderBy(document => document.CreatedAtUtc)
                .ThenBy(document => document.Title, StringComparer.OrdinalIgnoreCase),
            KnowledgeDocumentSort.Title => documents
                .OrderBy(document => document.Title, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(document => document.CreatedAtUtc),
            KnowledgeDocumentSort.Category => documents
                .OrderBy(GetCategoryName, StringComparer.OrdinalIgnoreCase)
                .ThenBy(document => document.Title, StringComparer.OrdinalIgnoreCase),
            KnowledgeDocumentSort.Tags => documents
                .OrderBy(GetTagSortValue, StringComparer.OrdinalIgnoreCase)
                .ThenBy(document => document.Title, StringComparer.OrdinalIgnoreCase),
            KnowledgeDocumentSort.Status => documents
                .OrderBy(document => document.ProcessingStatus, StringComparer.OrdinalIgnoreCase)
                .ThenBy(document => document.Title, StringComparer.OrdinalIgnoreCase),
            KnowledgeDocumentSort.SizeLargest => documents
                .OrderByDescending(document => document.SizeBytes)
                .ThenBy(document => document.Title, StringComparer.OrdinalIgnoreCase),
            KnowledgeDocumentSort.SizeSmallest => documents
                .OrderBy(document => document.SizeBytes)
                .ThenBy(document => document.Title, StringComparer.OrdinalIgnoreCase),
            _ => documents
                .OrderByDescending(document => document.CreatedAtUtc)
                .ThenBy(document => document.Title, StringComparer.OrdinalIgnoreCase)
        };

    private void ClearFilters()
    {
        _selectedCategoryId = 0;
        _selectedTagId = 0;
        _sortBy = KnowledgeDocumentSort.Newest;
        ApplyDocumentView();
    }

    private void SetFeedback(Severity severity, string message)
    {
        _feedbackSeverity = severity;
        _feedbackMessage = message;
    }

    private static string GetCategoryName(PortalKnowledgeDocumentResponse document)
        => document.Category?.Name ?? "Uncategorized";

    private static string GetTagSortValue(PortalKnowledgeDocumentResponse document)
        => document.Tags.Count == 0
            ? "zzzzzz"
            : string.Join(", ", document.Tags.Select(tag => tag.Name));

    private static Color GetDocumentColor(string status) => status switch
    {
        "Ready" => Color.Success,
        "AwaitingApproval" => Color.Warning,
        "Failed" => Color.Error,
        "Pending" => Color.Info,
        _ => Color.Default
    };

    private static string FormatFileSize(long sizeBytes)
    {
        if (sizeBytes >= 1024L * 1024L * 1024L)
            return $"{sizeBytes / (1024d * 1024d * 1024d):0.##} GB";

        if (sizeBytes >= 1024L * 1024L)
            return $"{sizeBytes / (1024d * 1024d):0.##} MB";

        if (sizeBytes >= 1024L)
            return $"{sizeBytes / 1024d:0.##} KB";

        return $"{sizeBytes} B";
    }

    private static string FormatCompactFileSize(long sizeBytes)
        => sizeBytes >= 1024L * 1024L
            ? $"{sizeBytes / (1024d * 1024d):0.#} MB"
            : FormatFileSize(sizeBytes);

    private enum KnowledgeDocumentSort
    {
        Newest,
        Oldest,
        Title,
        Category,
        Tags,
        Status,
        SizeLargest,
        SizeSmallest
    }
}

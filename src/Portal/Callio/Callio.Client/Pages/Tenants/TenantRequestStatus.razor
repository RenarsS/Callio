@page "/tenant-provisioning"
@page "/tenant-request-status"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using Callio.Client.Models
@inject Callio.Client.Services.PortalSessionService PortalSessionService
@inject Callio.Client.Services.TenantRequestApi TenantRequestApi
@inject Callio.Client.Services.TenantProvisioningApi TenantProvisioningApi
@inject NavigationManager Navigation

<PageTitle>Provisioning</PageTitle>

@if (_loading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_session is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Redirecting to sign in...
    </MudAlert>
}
else
{
    <TenantWorkspaceNav Session="_session" />

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4">@_error</MudAlert>
    }

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="4">
            <MudStack Spacing="3">
                <MudPaper Class="callio-card callio-card-strong pa-5" Elevation="0">
                    <div class="callio-kicker">Provisioning status</div>
                    <MudText Typo="Typo.h4" GutterBottom="true">Track onboarding, approval, and tenant infrastructure in one place.</MudText>
                    <MudText Typo="Typo.body2" Class="callio-lead">
                        This workspace reflects the signed-in customer user, so there is no manual tenant lookup. When approval completes, the page switches from request tracking into tenant provisioning details automatically.
                    </MudText>
                </MudPaper>

                @if (_requestStatus is not null)
                {
                    <MudPaper Class="callio-card pa-5" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">Tenant request</MudText>
                            <MudChip T="string" Size="Size.Small" Color="@GetRequestColor(_requestStatus.Status)" Variant="Variant.Filled">
                                @_requestStatus.Status
                            </MudChip>
                        </MudStack>

                        <MudText Typo="Typo.body2" Class="callio-lead mt-3">
                            @_requestStatus.TenantName
                            <br />
                            @_requestStatus.CompanyName
                        </MudText>

                        @if (!string.IsNullOrWhiteSpace(_requestStatus.SelectedPlanName))
                        {
                            <MudChip T="string" Class="mt-4" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                @($"Selected plan: {_requestStatus.SelectedPlanName}")
                            </MudChip>
                        }

                        @if (!string.IsNullOrWhiteSpace(_requestStatus.DecisionNote))
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">
                                @_requestStatus.DecisionNote
                            </MudAlert>
                        }
                    </MudPaper>
                }

                @if (_provisioningStatus is not null)
                {
                    <MudPaper Class="callio-card pa-5" Elevation="0">
                        <MudText Typo="Typo.h6" GutterBottom="true">Provisioned resources</MudText>
                        <div class="callio-detail-list mt-3">
                            <div class="callio-detail-item">
                                <span>Tenant database</span>
                                <strong>@_provisioningStatus.DatabaseSchema</strong>
                            </div>
                            <div class="callio-detail-item">
                                <span>Vector namespace</span>
                                <strong>@_provisioningStatus.VectorStoreNamespace</strong>
                            </div>
                            <div class="callio-detail-item">
                                <span>Attempts</span>
                                <strong>@_provisioningStatus.AttemptCount</strong>
                            </div>
                        </div>
                    </MudPaper>
                }
            </MudStack>
        </MudItem>

        <MudItem xs="12" lg="8">
            <MudStack Spacing="3">
                @if (_requestStatus is null)
                {
                    <MudPaper Class="callio-card pa-5" Elevation="0">
                        <MudText Typo="Typo.h5" GutterBottom="true">No onboarding request found</MudText>
                        <MudText Typo="Typo.body2" Class="callio-lead">
                            This account does not have a tenant request yet. Start onboarding to register a customer user and submit the first tenant request.
                        </MudText>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/tenant-registration" Class="mt-4">
                            Start onboarding
                        </MudButton>
                    </MudPaper>
                }
                else if (_session.TenantId is null)
                {
                    <MudPaper Class="callio-card pa-5" Elevation="0">
                        <MudText Typo="Typo.h5" GutterBottom="true">Waiting for tenant approval</MudText>
                        <MudText Typo="Typo.body2" Class="callio-lead">
                            @GetPendingMessage(_requestStatus)
                        </MudText>
                    </MudPaper>
                }
                else if (_provisioningStatus is null)
                {
                    <MudPaper Class="callio-card pa-5" Elevation="0">
                        <MudText Typo="Typo.h5" GutterBottom="true">Tenant approved, provisioning status pending</MudText>
                        <MudText Typo="Typo.body2" Class="callio-lead">
                            Your tenant has been approved and linked to tenant #@_session.TenantId.Value. The infrastructure status will appear here as soon as the provisioning service publishes the latest run.
                        </MudText>
                    </MudPaper>
                }
                else
                {
                    <MudPaper Class="callio-card pa-5" Elevation="0">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <div>
                                <MudText Typo="Typo.h5">Tenant infrastructure</MudText>
                                <MudText Typo="Typo.body2" Class="callio-lead">
                                    Current tenant: #@_provisioningStatus.TenantId
                                </MudText>
                            </div>
                            <MudChip T="string" Size="Size.Medium" Color="@GetProvisioningColor(_provisioningStatus.Status)" Variant="Variant.Filled">
                                @_provisioningStatus.Status
                            </MudChip>
                        </MudStack>

                        @if (!string.IsNullOrWhiteSpace(_provisioningStatus.LastError))
                        {
                            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-4">
                                @_provisioningStatus.LastError
                            </MudAlert>
                        }

                        <MudTable Items="_provisioningStatus.Steps.OrderBy(x => x.Order)" Dense="true" Hover="true" Class="mt-4">
                            <HeaderContent>
                                <MudTh>Step</MudTh>
                                <MudTh>Status</MudTh>
                                <MudTh>Attempts</MudTh>
                                <MudTh>Last completed</MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Name</MudTd>
                                <MudTd>
                                    <MudChip T="string" Size="Size.Small" Color="@GetProvisioningColor(context.Status)" Variant="Variant.Filled">
                                        @context.Status
                                    </MudChip>
                                    @if (!string.IsNullOrWhiteSpace(context.LastError))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Error">@context.LastError</MudText>
                                    }
                                </MudTd>
                                <MudTd>@context.AttemptCount</MudTd>
                                <MudTd>@(context.LastCompletedAtUtc.HasValue ? FormatUtc(context.LastCompletedAtUtc.Value) : "Pending")</MudTd>
                            </RowTemplate>
                        </MudTable>

                        @if (_provisioningStatus.KnowledgeConfigurationSetup is not null)
                        {
                            <MudDivider Class="my-4" />
                            <MudText Typo="Typo.h6">Knowledge configuration setup</MudText>
                            <MudText Typo="Typo.body2" Class="callio-lead mt-2">
                                Status: @_provisioningStatus.KnowledgeConfigurationSetup.Status
                            </MudText>
                        }
                    </MudPaper>
                }
            </MudStack>
        </MudItem>
    </MudGrid>
}

@code {
    private PortalUserSession? _session;
    private PortalTenantRequestStatusResponse? _requestStatus;
    private PortalTenantProvisioningStatusResponse? _provisioningStatus;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        _session = await PortalSessionService.RequireAuthenticatedAsync(returnUrl);
        if (_session is null)
        {
            _loading = false;
            return;
        }

        try
        {
            _requestStatus = await TenantRequestApi.GetCurrentRequestStatusAsync();

            if (_session.TenantId is > 0)
                _provisioningStatus = await TenantProvisioningApi.GetStatusAsync(_session.TenantId.Value);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static Color GetRequestColor(string status) => status switch
    {
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Warning
    };

    private static Color GetProvisioningColor(string status) => status switch
    {
        "Succeeded" => Color.Success,
        "Failed" => Color.Error,
        "InProgress" => Color.Info,
        _ => Color.Warning
    };

    private static string GetPendingMessage(PortalTenantRequestStatusResponse requestStatus) => requestStatus.Status switch
    {
        "Rejected" => "The onboarding request was rejected. Review the decision note and submit a new request if the tenant should be retried.",
        "Approved" => "The tenant request was approved. Tenant-specific provisioning details will appear here once the identity link refreshes into the workspace.",
        _ => "The request is still in review. Once approved, the tenant workspace and provisioning details will light up automatically."
    };

    private static string FormatUtc(DateTime value)
        => value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
}

@page "/tenant-request-status"
@rendermode InteractiveWebAssembly
@inject Callio.Client.Services.TenantRequestApi TenantRequestApi

<PageTitle>Request status</PageTitle>

<MudGrid Spacing="3">
    <MudItem xs="12" lg="4">
        <MudPaper Class="callio-card callio-card-strong pa-5" Elevation="0">
            <div class="callio-kicker">Customer status view</div>
            <MudText Typo="Typo.h4" GutterBottom="true">Check whether your tenant request is pending, approved, or rejected.</MudText>
            <MudText Typo="Typo.body2" Class="callio-lead">
                This page is the customer-facing handoff after submission. There is no duplex communication in this slice, so the latest decision and optional admin note are shown here.
            </MudText>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" lg="8">
        <MudStack Spacing="3">
            <MudPaper Class="callio-card pa-5" Elevation="0">
                <MudText Typo="Typo.h5" GutterBottom="true">Lookup request</MudText>

                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudNumericField @bind-Value="_lookup.RequestId" Label="Request ID" Variant="Variant.Outlined" Min="1" />
                    </MudItem>
                    <MudItem xs="12" md="8">
                        <MudTextField @bind-Value="_lookup.Email" Label="Email" Variant="Variant.Outlined" InputType="InputType.Email" />
                    </MudItem>
                </MudGrid>

                <MudStack Row="true" Spacing="2" Class="mt-4">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" ButtonType="ButtonType.Button" Disabled="@(_loading || !CanLookup)" OnClick="LookupAsync">
                        @(_loading ? "Loading..." : "Load request status")
                    </MudButton>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tenant-registration">Submit a new request</MudButton>
                </MudStack>
            </MudPaper>

            @if (!string.IsNullOrWhiteSpace(_error))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_error</MudAlert>
            }

            @if (_status is not null)
            {
                <MudPaper Class="callio-card pa-5" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                        <div>
                            <MudText Typo="Typo.h5">@_status.TenantName</MudText>
                            <MudText Typo="Typo.body2" Class="callio-lead">@_status.CompanyName</MudText>
                        </div>
                        <MudChip T="string" Size="Size.Medium" Color="@GetStatusColor(_status.Status)" Variant="Variant.Filled">
                            @_status.Status
                        </MudChip>
                    </MudStack>

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.body2" Class="callio-lead">@GetStatusMessage(_status)</MudText>

                    @if (!string.IsNullOrWhiteSpace(_status.DecisionNote))
                    {
                        <MudPaper Class="callio-card mt-4 pa-4" Elevation="0">
                            <MudText Typo="Typo.subtitle1">Admin note</MudText>
                            <MudText Typo="Typo.body2" Class="callio-lead">@_status.DecisionNote</MudText>
                        </MudPaper>
                    }
                </MudPaper>
            }
        </MudStack>
    </MudItem>
</MudGrid>

@code {
    [SupplyParameterFromQuery(Name = "requestId")]
    public int? QueryRequestId { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? QueryEmail { get; set; }

    private readonly RequestLookupVm _lookup = new();
    private bool _loading;
    private bool _queryInitialized;
    private string? _error;
    private Callio.Client.Services.PortalTenantRequestStatusResponse? _status;

    private bool CanLookup => _lookup.RequestId > 0 && !string.IsNullOrWhiteSpace(_lookup.Email);

    protected override async Task OnParametersSetAsync()
    {
        if (_queryInitialized)
            return;

        if (QueryRequestId is > 0 && !string.IsNullOrWhiteSpace(QueryEmail))
        {
            _lookup.RequestId = QueryRequestId.Value;
            _lookup.Email = QueryEmail;
            _queryInitialized = true;
            await LookupAsync();
        }
    }

    private async Task LookupAsync()
    {
        if (!CanLookup)
        {
            _error = "Enter the request ID and email used when the request was created.";
            return;
        }

        _loading = true;
        _error = null;

        try
        {
            _status = await TenantRequestApi.GetRequestStatusAsync(_lookup.RequestId, _lookup.Email!);
        }
        catch (Exception ex)
        {
            _status = null;
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        _ => Color.Warning
    };

    private static string GetStatusMessage(Callio.Client.Services.PortalTenantRequestStatusResponse status) => status.Status switch
    {
        "Approved" => $"Your tenant request was approved{(status.TenantId.HasValue ? $" and linked to tenant #{status.TenantId.Value}." : ".")}",
        "Rejected" => "Your tenant request was rejected. Review the admin note if one was provided before submitting again.",
        _ => "Your tenant request is still pending dashboard review."
    };

    private sealed class RequestLookupVm
    {
        public int RequestId { get; set; }
        public string? Email { get; set; }
    }
}

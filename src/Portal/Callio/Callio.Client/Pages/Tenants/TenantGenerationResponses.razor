@page "/tenant-generation-responses"
@page "/tenant-response-storage"
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@using Callio.Client.Models
@inject Callio.Client.Services.PortalSessionService PortalSessionService
@inject Callio.Client.Services.TenantGenerationApi TenantGenerationApi
@inject NavigationManager Navigation

<PageTitle>Response storage</PageTitle>

@if (_loadingSession)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else if (_session is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
        Redirecting to sign in...
    </MudAlert>
}
else if (_tenantId is null)
{
    <TenantWorkspaceNav Session="_session" />

    <MudPaper Class="callio-card pa-5" Elevation="0">
        <MudText Typo="Typo.h5" GutterBottom="true">Response storage unlocks after tenant approval</MudText>
        <MudText Typo="Typo.body2" Class="callio-lead">
            This account has not been linked to an approved tenant yet. Check provisioning to follow approval and infrastructure progress.
        </MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/tenant-provisioning" Class="mt-4">
            Open provisioning
        </MudButton>
    </MudPaper>
}
else
{
    <TenantWorkspaceNav Session="_session" />

    <MudGrid Spacing="3">
        <MudItem xs="12" lg="4">
            <MudStack Spacing="3">
                <MudPaper Class="callio-card callio-card-strong pa-5" Elevation="0">
                    <div class="callio-kicker">Response storage</div>
                    <MudText Typo="Typo.h4" GutterBottom="true">Browse saved tenant generations without opening the generation form.</MudText>
                    <MudText Typo="Typo.body2" Class="callio-lead">
                        Filter saved responses by prompt or status, then sort the history for review and audit work.
                    </MudText>
                    <MudStack Row="true" Spacing="2" Class="mt-4">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/tenant-response-generation">
                            Generate response
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/tenant-generation-prompts">
                            Prompt storage
                        </MudButton>
                    </MudStack>
                </MudPaper>

                @if (_responses.Count > 0)
                {
                    <div class="callio-stat-row">
                        <div class="callio-stat">
                            <div class="callio-stat-label">Visible</div>
                            <div class="callio-stat-value">@_filteredResponses.Count</div>
                        </div>
                        <div class="callio-stat">
                            <div class="callio-stat-label">Completed</div>
                            <div class="callio-stat-value">@_filteredResponses.Count(x => x.Status == "Completed")</div>
                        </div>
                        <div class="callio-stat">
                            <div class="callio-stat-label">Sources</div>
                            <div class="callio-stat-value">@_filteredResponses.Sum(x => x.Sources.Count)</div>
                        </div>
                    </div>
                }

                <MudPaper Class="callio-card pa-5" Elevation="0">
                    <MudText Typo="Typo.h6" GutterBottom="true">Available templates</MudText>
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                        @_prompts.Count prompt(s)
                    </MudChip>
                </MudPaper>
            </MudStack>
        </MudItem>

        <MudItem xs="12" lg="8">
            <MudStack Spacing="3">
                @if (!string.IsNullOrWhiteSpace(_feedbackMessage))
                {
                    <MudAlert Severity="@_feedbackSeverity" Variant="Variant.Outlined">@_feedbackMessage</MudAlert>
                }

                <MudPaper Class="callio-card pa-5" Elevation="0">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                        <div>
                            <MudText Typo="Typo.h5">Saved responses</MudText>
                            <MudText Typo="Typo.body2" Class="callio-lead">
                                Recent saved generations for tenant #@_tenantId.Value, separated from the response generation workflow.
                            </MudText>
                        </div>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                            @_filteredResponses.Count of @_responses.Count response(s)
                        </MudChip>
                    </MudStack>

                    <MudGrid Class="mb-4">
                        <MudItem xs="12" md="4">
                            <label class="callio-filter-label" for="response-prompt-filter">Prompt filter</label>
                            <select id="response-prompt-filter" class="callio-filter-select" @bind="_selectedPromptKey" @bind:after="ApplyResponseView">
                                <option value="@AllFilterValue">All prompts</option>
                                @foreach (var prompt in _prompts)
                                {
                                    <option value="@prompt.Key">@prompt.Name</option>
                                }
                            </select>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <label class="callio-filter-label" for="response-status-filter">Status filter</label>
                            <select id="response-status-filter" class="callio-filter-select" @bind="_selectedStatus" @bind:after="ApplyResponseView">
                                <option value="@AllFilterValue">All statuses</option>
                                @foreach (var status in ResponseStatuses)
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                        </MudItem>
                        <MudItem xs="12" md="4">
                            <label class="callio-filter-label" for="response-sort">Sort by</label>
                            <select id="response-sort" class="callio-filter-select" @bind="_sortBy" @bind:after="ApplyResponseView">
                                <option value="@GenerationResponseSort.Newest">Newest generation</option>
                                <option value="@GenerationResponseSort.Oldest">Oldest generation</option>
                                <option value="@GenerationResponseSort.Prompt">Prompt</option>
                                <option value="@GenerationResponseSort.Status">Status</option>
                                <option value="@GenerationResponseSort.InputTokens">Input tokens</option>
                                <option value="@GenerationResponseSort.OutputTokens">Output tokens</option>
                                <option value="@GenerationResponseSort.SourceCount">Source count</option>
                            </select>
                        </MudItem>
                        <MudItem xs="12">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">
                                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Disabled="@_loading" OnClick="ClearFilters">
                                    Clear filters
                                </MudButton>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@_loading" OnClick="LoadAsync">
                                    @(_loading ? "Refreshing..." : "Refresh")
                                </MudButton>
                            </MudStack>
                        </MudItem>
                    </MudGrid>

                    @if (_loading)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-4" />
                    }

                    @if (_responses.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="callio-lead">
                            No saved responses exist for this tenant yet.
                        </MudText>
                    }
                    else if (_filteredResponses.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Class="callio-lead">
                            No saved responses match the selected filters.
                        </MudText>
                    }
                    else
                    {
                        <MudExpansionPanels MultiExpansion="true">
                            @foreach (var response in _filteredResponses)
                            {
                                <MudExpansionPanel Text="@($"{response.PromptName} - {FormatUtc(response.CreatedAtUtc)}")">
                                    <MudStack Spacing="2">
                                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                                            <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(response.Status)" Variant="Variant.Filled">
                                                @response.Status
                                            </MudChip>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">
                                                @response.PromptKey
                                            </MudChip>
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                                @($"{response.Sources.Count} source(s)")
                                            </MudChip>
                                        </MudStack>

                                        <MudText Typo="Typo.subtitle2">Input</MudText>
                                        <MudText Typo="Typo.body2" Class="callio-lead">@response.Input</MudText>

                                        <MudText Typo="Typo.subtitle2">Response</MudText>
                                        <MudText Typo="Typo.body2" Class="callio-lead">@response.ResponseText</MudText>

                                        <MudText Typo="Typo.subtitle2">Prompt metadata</MudText>
                                        <div class="callio-plan-card-quotas">
                                            <div class="callio-plan-card-quota">@response.GenerationModel</div>
                                            <div class="callio-plan-card-quota">@($"Input tokens: {response.EstimatedInputTokens}")</div>
                                            <div class="callio-plan-card-quota">@($"Output tokens: {response.EstimatedOutputTokens}")</div>
                                        </div>

                                        @if (response.Sources.Count > 0)
                                        {
                                            <MudText Typo="Typo.subtitle2" Class="mt-2">Supporting sources</MudText>
                                            @foreach (var source in response.Sources)
                                            {
                                                <MudPaper Outlined="true" Class="pa-3">
                                                    <MudText Typo="Typo.caption">@source.SourceKind</MudText>
                                                    <MudText Typo="Typo.body2">@source.DocumentTitle</MudText>
                                                    <MudText Typo="Typo.caption" Class="callio-lead">@source.ContentExcerpt</MudText>
                                                </MudPaper>
                                            }
                                        }
                                    </MudStack>
                                </MudExpansionPanel>
                            }
                        </MudExpansionPanels>
                    }
                </MudPaper>
            </MudStack>
        </MudItem>
    </MudGrid>
}

@code {
    private const string AllFilterValue = "__all";

    private PortalUserSession? _session;
    private int? _tenantId;
    private bool _loadingSession = true;
    private bool _loading;
    private string? _feedbackMessage;
    private Severity _feedbackSeverity = Severity.Info;
    private IReadOnlyList<PortalGenerationPromptResponse> _prompts = [];
    private IReadOnlyList<PortalGenerationResponse> _responses = [];
    private List<PortalGenerationResponse> _filteredResponses = [];
    private string _selectedPromptKey = AllFilterValue;
    private string _selectedStatus = AllFilterValue;
    private GenerationResponseSort _sortBy = GenerationResponseSort.Newest;

    private IReadOnlyList<string> ResponseStatuses
        => _responses
            .Select(response => response.Status)
            .Where(status => !string.IsNullOrWhiteSpace(status))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(status => status, StringComparer.OrdinalIgnoreCase)
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        _session = await PortalSessionService.RequireAuthenticatedAsync(returnUrl);
        _tenantId = _session?.TenantId;
        _loadingSession = false;

        if (_tenantId is > 0)
            await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (_tenantId is not > 0)
            return;

        _loading = true;
        _feedbackMessage = null;

        try
        {
            _prompts = await TenantGenerationApi.GetPromptsAsync(_tenantId.Value);
            _responses = await TenantGenerationApi.GetResponsesAsync(_tenantId.Value, 100);
            ApplyResponseView();
        }
        catch (Exception ex)
        {
            _prompts = [];
            _responses = [];
            _filteredResponses = [];
            SetFeedback(Severity.Error, ex.Message);
        }
        finally
        {
            _loading = false;
        }
    }

    private void ApplyResponseView()
        => _filteredResponses = SortResponses(FilterResponses()).ToList();

    private IEnumerable<PortalGenerationResponse> FilterResponses()
    {
        var responses = _responses.AsEnumerable();

        if (!string.Equals(_selectedPromptKey, AllFilterValue, StringComparison.Ordinal))
            responses = responses.Where(response => string.Equals(response.PromptKey, _selectedPromptKey, StringComparison.OrdinalIgnoreCase));

        if (!string.Equals(_selectedStatus, AllFilterValue, StringComparison.Ordinal))
            responses = responses.Where(response => string.Equals(response.Status, _selectedStatus, StringComparison.OrdinalIgnoreCase));

        return responses;
    }

    private IEnumerable<PortalGenerationResponse> SortResponses(IEnumerable<PortalGenerationResponse> responses)
        => _sortBy switch
        {
            GenerationResponseSort.Oldest => responses
                .OrderBy(response => response.CreatedAtUtc)
                .ThenBy(response => response.PromptName, StringComparer.OrdinalIgnoreCase),
            GenerationResponseSort.Prompt => responses
                .OrderBy(response => response.PromptName, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(response => response.CreatedAtUtc),
            GenerationResponseSort.Status => responses
                .OrderBy(response => response.Status, StringComparer.OrdinalIgnoreCase)
                .ThenByDescending(response => response.CreatedAtUtc),
            GenerationResponseSort.InputTokens => responses
                .OrderByDescending(response => response.EstimatedInputTokens)
                .ThenByDescending(response => response.CreatedAtUtc),
            GenerationResponseSort.OutputTokens => responses
                .OrderByDescending(response => response.EstimatedOutputTokens)
                .ThenByDescending(response => response.CreatedAtUtc),
            GenerationResponseSort.SourceCount => responses
                .OrderByDescending(response => response.Sources.Count)
                .ThenByDescending(response => response.CreatedAtUtc),
            _ => responses
                .OrderByDescending(response => response.CreatedAtUtc)
                .ThenBy(response => response.PromptName, StringComparer.OrdinalIgnoreCase)
        };

    private void ClearFilters()
    {
        _selectedPromptKey = AllFilterValue;
        _selectedStatus = AllFilterValue;
        _sortBy = GenerationResponseSort.Newest;
        ApplyResponseView();
    }

    private void SetFeedback(Severity severity, string message)
    {
        _feedbackSeverity = severity;
        _feedbackMessage = message;
    }

    private static string FormatUtc(DateTime value)
        => value.ToLocalTime().ToString("yyyy-MM-dd HH:mm");

    private static Color GetStatusColor(string status) => status switch
    {
        "Completed" => Color.Success,
        "Failed" => Color.Error,
        _ => Color.Info
    };

    private enum GenerationResponseSort
    {
        Newest,
        Oldest,
        Prompt,
        Status,
        InputTokens,
        OutputTokens,
        SourceCount
    }
}

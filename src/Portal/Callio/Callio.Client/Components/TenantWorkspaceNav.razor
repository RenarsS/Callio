@using Callio.Client.Models
@inject Callio.Client.Services.PortalSessionService PortalSessionService

<MudPaper Class="callio-card pa-4 mb-4" Elevation="0">
    <MudStack Spacing="2">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
            <div>
                <div class="callio-kicker">Customer workspace</div>
                <MudText Typo="Typo.h6">@Session.DisplayName</MudText>
                <MudText Typo="Typo.body2" Class="callio-lead">
                    @Session.Email
                    @if (Session.TenantId.HasValue)
                    {
                        @($" • Tenant #{Session.TenantId.Value}")
                    }
                </MudText>
            </div>

            <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="LogoutAsync">
                Sign out
            </MudButton>
        </MudStack>

        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tenant-dashboard">Dashboard</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tenant-provisioning">Provisioning</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tenant-knowledge-settings">Knowledge settings</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tenant-knowledge-library">Knowledge library</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tenant-generation-prompts">Prompt storage</MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/tenant-generation-responses">Response storage</MudButton>
        </MudStack>
    </MudStack>
</MudPaper>

@code {
    [Parameter, EditorRequired]
    public PortalUserSession Session { get; set; } = default!;

    private Task LogoutAsync()
        => PortalSessionService.LogoutAsync();
}
